# =============================================================================
# 環境變數範例 - 複製為 .env 後填入實際值
# 請勿將 .env 或含機密的檔案 commit 到版控（.env 應已在 .gitignore）
# =============================================================================

# ---------- 必填 ----------
# 資料庫連線字串（Prisma 使用）
DATABASE_URL=postgresql://user:password@localhost:5432/erp

# NextAuth 登入用
# 本機開發可設為 http://localhost:3000；部署時改為實際網址
NEXTAUTH_URL=http://localhost:3000
# 至少 32 字元的隨機字串，可用: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars

# ---------- 選填 ----------
# 服務埠，預設 3000
# PORT=3000

# 是否啟用排程（備份等），預設不啟用
# ENABLE_SCHEDULER=true

# Seed 預設管理員密碼（僅首次 prisma db seed 時使用）
# ADMIN_DEFAULT_PASSWORD=a-strong-password-here

# OCR 服務
# OCR_SERVICE_URL=http://localhost:5001

# Google Vision API（OCR 服務使用）
# GOOGLE_VISION_API_KEY=your-google-vision-api-key

# 備份檔案存放根目錄（預設 ./backup-data）
# BACKUP_ROOT=/path/to/backup-data

# 備份加密金鑰（AES-256-GCM，64 個十六進位字元 = 32 bytes）
# 產生方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BACKUP_ENCRYPTION_KEY=your-64-hex-char-key-here

# PostgreSQL 工具路徑（若不在 PATH 中則需指定完整路徑）
# PG_DUMP_PATH=/usr/lib/postgresql/15/bin/pg_dump
# PG_RESTORE_PATH=/usr/lib/postgresql/15/bin/pg_restore
# PSQL_PATH=/usr/lib/postgresql/15/bin/psql
