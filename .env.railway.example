# Railway Cloud Database - 連線範例
# 使用說明:
# 1. 複製此檔為 .env:  cp .env.railway.example .env
# 2. 從 Railway Dashboard → PostgreSQL 服務 → Variables/Connect 取得 DATABASE_URL
# 3. 貼上完整連線字串，替換下面的 placeholder
# 4. 本地 Docker 只跑 app（不跑本地 db）:  docker compose up app -d
#    或跑全部（含本地 db）:  docker compose up -d
# 5. Schema 同步: entrypoint 會自動執行 prisma db push

# 從 Railway Dashboard 複製完整的 connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@HOST.rlwy.net:PORT/railway?schema=public

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_random_secret_key_at_least_32_chars
