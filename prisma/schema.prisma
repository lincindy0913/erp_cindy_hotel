// ============================================
// 備份還原演練紀錄
// ============================================

model RestoreDrill {
  id              Int       @id @default(autoincrement())
  backupRecordId  Int       @map("backup_record_id")
  status          String    @default("in_progress") @db.VarChar(20) // in_progress, passed, failed
  // Test results (5-point verification)
  fileIntegrity   Boolean?  @map("file_integrity")
  checksumMatch   Boolean?  @map("checksum_match")
  dataReadable    Boolean?  @map("data_readable")
  recordCountMatch Boolean? @map("record_count_match")
  sampleDataValid Boolean?  @map("sample_data_valid")
  // Actual restore test results
  actualRestore   Boolean?  @map("actual_restore")       // 是否執行了實際還原測試
  restoreMethod   String?   @map("restore_method") @db.VarChar(50) // pg_restore_temp_schema, json_validate_insert, file_only
  tablesExpected  Int?      @map("tables_expected")
  tablesRestored  Int?      @map("tables_restored")
  recordsExpected Int?      @map("records_expected")
  recordsRestored Int?      @map("records_restored")
  // RTO/RPO metrics
  restoreDurationMs Int?    @map("restore_duration_ms")   // 還原耗時（毫秒）= RTO 實測
  dataAgeMinutes    Int?    @map("data_age_minutes")      // 備份資料年齡（分鐘）= RPO 實測
  rtoCompliant    Boolean?  @map("rto_compliant")         // 是否符合 RTO 目標
  rpoCompliant    Boolean?  @map("rpo_compliant")         // 是否符合 RPO 目標
  rtoTargetMinutes Int?     @map("rto_target_minutes")    // 演練時的 RTO 目標快照
  rpoTargetHours   Int?     @map("rpo_target_hours")      // 演練時的 RPO 目標快照
  // Metadata
  details         Json?
  errorMessage    String?   @map("error_message") @db.Text
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  triggeredBy     String?   @map("triggered_by") @db.VarChar(255)

  backup BackupRecord @relation(fields: [backupRecordId], references: [id])

  @@index([backupRecordId])
  @@index([status])
  @@index([startedAt])
  @@map("restore_drills")
}

