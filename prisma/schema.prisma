  targetId          Int?      @map("target_id")
  targetNo          String?   @map("target_no") @db.VarChar(100)
  amount            Decimal?  @db.Decimal(14, 2)
  previousAuditId   Int?      @map("previous_audit_id") // Links approval → execution chain
  auditLogId        Int       @map("audit_log_id")
  complianceResult  String?   @map("compliance_result") @db.VarChar(20) // pass, warning, fail
  complianceDetails Json?     @map("compliance_details")
  note              String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")

  auditLog AuditLog @relation(fields: [auditLogId], references: [id])

  @@index([operationCode])
  @@index([operatorId])
  @@index([targetModule, targetId])
  @@index([createdAt])
  @@map("critical_operation_records")
}

// ============================================
// 工程會計 (營造公司：工程案、合約期數、材料)
// ============================================

model EngineeringProject {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50)
  name         String    @db.VarChar(255)
  clientName   String?    @map("client_name") @db.VarChar(255)
  startDate    String?   @map("start_date") @db.VarChar(20)
  endDate      String?   @map("end_date") @db.VarChar(20)
  budget       Decimal?  @db.Decimal(14, 2)
  status       String    @default("進行中") @db.VarChar(20)
  warehouse    String?   @db.VarChar(100)
  warehouseId  Int?      @map("warehouse_id")
  departmentId Int?      @map("department_id")
  location     String?   @db.VarChar(500)
  buildingNo   String?   @map("building_no") @db.VarChar(100)
  permitNo     String?   @map("permit_no") @db.VarChar(100)
  note         String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  warehouseRef  Warehouse?  @relation(fields: [warehouseId], references: [id])
  departmentRef Department? @relation(fields: [departmentId], references: [id])
  contracts     EngineeringContract[]
  materials     EngineeringMaterial[]

  @@index([status])
  @@index([warehouse])
  @@index([warehouseId])
  @@map("engineering_projects")
}

model EngineeringContract {
  id           Int      @id @default(autoincrement())
  projectId    Int      @map("project_id")
  supplierId   Int      @map("supplier_id")
  contractNo   String   @map("contract_no") @db.VarChar(100)
  totalAmount  Decimal  @map("total_amount") @db.Decimal(14, 2)
  signDate     String?  @map("sign_date") @db.VarChar(20)
  status       String   @default("active") @db.VarChar(20)
  content      String?  @db.Text
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project   EngineeringProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier  Supplier                  @relation(fields: [supplierId], references: [id])
  terms     EngineeringContractTerm[]
  materials EngineeringMaterial[]

  @@unique([projectId, contractNo])
  @@index([projectId])
  @@index([supplierId])
  @@map("engineering_contracts")
}

model EngineeringContractTerm {
  id              Int       @id @default(autoincrement())
  contractId      Int       @map("contract_id")
  termNo          Int       @map("term_no")
  termName        String?   @map("term_name") @db.VarChar(100)
  content         String?   @db.Text
  amount          Decimal   @db.Decimal(14, 2)
  dueDate         String?   @map("due_date") @db.VarChar(20)
  status          String    @default("pending") @db.VarChar(20)
  paidAt          String?   @map("paid_at") @db.VarChar(20)
  paymentOrderId  Int?      @map("payment_order_id")
  note            String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contract  EngineeringContract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  materials EngineeringMaterial[]

  @@index([contractId])
  @@index([status])
  @@map("engineering_contract_terms")
}

model EngineeringMaterial {
  id          Int      @id @default(autoincrement())
  projectId   Int      @map("project_id")
  contractId  Int?     @map("contract_id")
  termId      Int?     @map("term_id")
  productId   Int?     @map("product_id")
  description String? @db.VarChar(500)
  quantity    Decimal  @db.Decimal(12, 4)
  unit        String?  @db.VarChar(20)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  usedAt      String?  @map("used_at") @db.VarChar(20)
  note        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project  EngineeringProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract EngineeringContract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  term     EngineeringContractTerm? @relation(fields: [termId], references: [id], onDelete: SetNull)
  product  Product?                 @relation(fields: [productId], references: [id])

  @@index([projectId])
  @@index([contractId])
  @@index([termId])
  @@index([productId])
  @@map("engineering_materials")
}

// ============================================
// 進貨折讓管理
// ============================================

model PurchaseAllowance {
  id                  Int       @id @default(autoincrement())
  allowanceNo         String    @unique @map("allowance_no") @db.VarChar(50)
  allowanceType       String    @default("折讓") @map("allowance_type") @db.VarChar(20)
  allowanceDate       String    @map("allowance_date") @db.VarChar(20)
  supplierId          Int?      @map("supplier_id")
  supplierName        String?   @map("supplier_name") @db.VarChar(255)
  warehouse           String?   @db.VarChar(100)
  purchaseId          Int?      @map("purchase_id")
  purchaseNo          String?   @map("purchase_no") @db.VarChar(50)
  invoiceId           Int?      @map("invoice_id")
  invoiceNo           String?   @map("invoice_no") @db.VarChar(50)
  paymentOrderId      Int?      @map("payment_order_id")
  paymentOrderNo      String?   @map("payment_order_no") @db.VarChar(50)
  amount              Decimal   @default(0) @db.Decimal(12, 2)
  tax                 Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  refundAccountId     Int?      @map("refund_account_id")
  cashTransactionId   Int?      @map("cash_transaction_id")
  cashTransactionNo   String?   @map("cash_transaction_no") @db.VarChar(50)
  status              String    @default("草稿") @db.VarChar(20)
  reason              String?   @db.Text
  note                String?   @db.Text
  confirmedBy         String?   @map("confirmed_by") @db.VarChar(255)
  confirmedAt         DateTime? @map("confirmed_at")
  createdBy           String?   @map("created_by") @db.VarChar(255)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  details             AllowanceDetail[]

  @@index([supplierId])
  @@index([warehouse])
  @@index([status])
  @@index([allowanceDate])
  @@index([purchaseId])
  @@index([invoiceId])
  @@index([paymentOrderId])
  @@map("purchase_allowances")
}

model AllowanceDetail {
  id              Int      @id @default(autoincrement())
  allowanceId     Int      @map("allowance_id")
  productName     String?  @map("product_name") @db.VarChar(255)
  quantity        Decimal  @default(0) @db.Decimal(12, 4)
  unitPrice       Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  subtotal        Decimal  @default(0) @db.Decimal(12, 2)
  reason          String?  @db.Text

  allowance       PurchaseAllowance @relation(fields: [allowanceId], references: [id], onDelete: Cascade)

  @@index([allowanceId])
  @@map("allowance_details")
}
