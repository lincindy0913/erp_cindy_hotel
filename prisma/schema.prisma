  monthlyRent                   Decimal   @map("monthly_rent") @db.Decimal(12, 2)
  paymentDueDay                 Int       @map("payment_due_day")
  preferredPayMethod            String?   @map("preferred_pay_method") @db.VarChar(20)
  depositAmount                 Decimal   @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  depositAccountId              Int?      @map("deposit_account_id")
  depositReceived               Boolean   @default(false) @map("deposit_received")
  depositCashTransactionId      Int?      @map("deposit_cash_transaction_id")
  depositRefunded               Boolean   @default(false) @map("deposit_refunded")
  depositRefundCashTransactionId Int?     @map("deposit_refund_cash_transaction_id")
  depositRefundPaymentOrderId    Int?     @map("deposit_refund_payment_order_id")
