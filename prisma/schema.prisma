  checkId           Int?     @map("check_id")
  note              String?  @db.Text
  status            String   @default("已確認") @db.VarChar(20)
  executedBy        String?  @map("executed_by") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id])

  @@index([paymentOrderId])
  @@index([accountId])
  @@map("cashier_executions")
}

// ============================================
// 常見費用範本系統 (spec10)
// ============================================

model CommonExpenseTemplate {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  summary         String?   @db.VarChar(500)   // 摘要
  templateType    String    @default("fixed") @map("template_type") @db.VarChar(20) // purchase, fixed
  categoryId      Int?      @map("category_id")
  warehouse       String?   @db.VarChar(100)
  defaultSupplierId Int?    @map("default_supplier_id")
  paymentMethod   String?   @map("payment_method") @db.VarChar(50)
  purchaseItems   Json?     @map("purchase_items")   // For purchase type: [{productId, quantity, unitPrice, note}]
  defaultTaxType  String?   @map("default_tax_type") @db.VarChar(20)
  // 固定費用：各館別對應支出存簿 [{ warehouse, accountId }]
  warehouseAccountMap Json? @map("warehouse_account_map")
  warehouseAmounts Json?    @map("warehouse_amounts") // legacy [{ warehouse, defaultAmount }]
