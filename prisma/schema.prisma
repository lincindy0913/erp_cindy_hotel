// 進銷存暨營運決策分析系統 - Prisma Schema
// PostgreSQL Database
// Updated: 2026-03-04 (spec0-spec28 complete integration)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 主資料層 (spec0)
// ============================================

model Product {
  id                Int      @id @default(autoincrement())
  code              String   @unique @db.VarChar(50)
  name              String   @db.VarChar(255)
  productType       String   @default("goods") @map("product_type") @db.VarChar(20) // goods, service, consumable
  category          String?  @db.VarChar(100)
  unit              String?  @db.VarChar(20)
  costPrice         Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  salesPrice        Decimal  @default(0) @map("sales_price") @db.Decimal(12, 2)
  isInStock         Boolean  @default(false) @map("is_in_stock")
  lowStockThreshold Int?     @map("low_stock_threshold") // spec24: 庫存偏低閾值
  warehouseLocation String?  @map("warehouse_location") @db.VarChar(50)
  accountingSubject String?  @map("accounting_subject") @db.VarChar(100)
  supplierId        Int?     @map("supplier_id")
  isActive          Boolean  @default(true) @map("is_active")
  note              String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  supplier             Supplier?                @relation(fields: [supplierId], references: [id])
  purchaseDetails      PurchaseDetail[]
  priceHistories       PriceHistory[]
  priceComparisons     PriceComparison[]
  priceSummaryCaches   PriceSummaryCache[]
  inventorySnapshots   InventoryMonthlySnapshot[]
  lowStockCaches       InventoryLowStockCache[]
  inventoryRequisitions InventoryRequisition[]
  inventoryTransferItems InventoryTransferItem[]
  stockCountItems      StockCountItem[]
  engineeringMaterials EngineeringMaterial[]

  @@index([code])
  @@index([name])
  @@index([category])
  @@index([isInStock])
  @@index([supplierId])
  @@index([productType])
  @@map("products")
}

model Supplier {
  id              Int       @id @default(autoincrement())
  supplierCode    String?   @unique @map("supplier_code") @db.VarChar(50) // SUP-XXXXXX
  name            String    @db.VarChar(255)
  taxId           String?   @unique @map("tax_id") @db.VarChar(50)
  contact         String?   @db.VarChar(255)
  personInCharge  String?   @map("person_in_charge") @db.VarChar(255)
  phone           String?   @db.VarChar(50)
  address         String?   @db.VarChar(500)
  email           String?   @db.VarChar(255)
  paymentTerms    String?   @map("payment_terms") @db.VarChar(100)
  bankName        String?   @map("bank_name") @db.VarChar(100)
  bankAccount     String?   @map("bank_account") @db.VarChar(100)
  contractDate    String?   @map("contract_date") @db.VarChar(20)
  contractEndDate String?   @map("contract_end_date") @db.VarChar(20)
  paymentStatus   String?   @default("未付款") @map("payment_status") @db.VarChar(20)
  remarks         String?   @db.Text
  sortOrder       Int?      @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  products            Product[]
  purchaseMasters     PurchaseMaster[]
  contracts           SupplierContract[]
  engineeringContracts EngineeringContract[]
  priceHistories      PriceHistory[]
  priceComparisons    PriceComparison[]
  priceSummaryCaches  PriceSummaryCache[]
  expenses            Expense[]

  @@index([sortOrder])
  @@index([paymentStatus])
  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

// ============================================
// 館別與部門 (spec0)
// ============================================

model Warehouse {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  code        String?      @unique @db.VarChar(20)
  /// storage=倉庫(實體儲存地點，如地下室、備品室、2F倉庫)；building=館別(如麗格，底下有部門與倉庫)
  type        String       @default("storage") @db.VarChar(20)
  parentId    Int?         @map("parent_id")
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int?         @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")

  parent            Warehouse?          @relation("WarehouseChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children          Warehouse[]          @relation("WarehouseChildren")
  departments       Department[]
  engineeringProjects EngineeringProject[]
  creditCardMerchantConfigs CreditCardMerchantConfig[]

  @@unique([parentId, name])
  @@index([type])
  @@map("warehouses")
}

model Department {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  warehouseId Int       @map("warehouse_id")
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int?      @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  warehouse           Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  engineeringProjects EngineeringProject[]

  @@unique([warehouseId, name])
  @@map("departments")
}

// ============================================
// 廠商合約
// ============================================

model SupplierContract {
  id         Int      @id @default(autoincrement())
  supplierId Int      @map("supplier_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  fileSize   Int      @map("file_size")
  fileType   String   @map("file_type") @db.VarChar(100)
  fileData   Bytes    @map("file_data")
  uploadDate DateTime @default(now()) @map("upload_date")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([supplierId])
  @@map("supplier_contracts")
}

// ============================================
// 進貨模組 (spec1)
// ============================================

model PurchaseMaster {
  id           Int      @id @default(autoincrement())
  purchaseNo   String   @unique @map("purchase_no") @db.VarChar(50)
  warehouse    String?  @db.VarChar(100)
  department   String?  @db.VarChar(100)
  supplierId   Int      @map("supplier_id")
  purchaseDate String   @map("purchase_date") @db.VarChar(20)
  paymentTerms String?  @map("payment_terms") @db.VarChar(100)
  taxType      String?  @map("tax_type") @db.VarChar(20)
  amount       Decimal  @default(0) @db.Decimal(12, 2)
  tax          Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  status       String   @default("待入庫") @db.VarChar(20)
  version      Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  supplier Supplier         @relation(fields: [supplierId], references: [id])
  details  PurchaseDetail[]

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([warehouse])
  @@index([purchaseNo])
  @@index([status])
  @@map("purchase_masters")
}

model PurchaseDetail {
  id         Int     @id @default(autoincrement())
  purchaseId Int     @map("purchase_id")
  productId  Int     @map("product_id")
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  note               String? @db.Text
  status             String  @default("待入庫") @db.VarChar(20)
  inventoryWarehouse String? @map("inventory_warehouse") @db.VarChar(100)

  purchaseMaster PurchaseMaster @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@index([productId, purchaseId]) // spec24: 快照後增量查詢
  @@map("purchase_details")
}

// ============================================
// 銷貨/發票模組 (spec2)
// ============================================

model SalesMaster {
  id               Int      @id @default(autoincrement())
  salesNo          String   @unique @map("sales_no") @db.VarChar(50)
  invoiceNo        String   @map("invoice_no") @db.VarChar(50)
  invoiceDate      String   @map("invoice_date") @db.VarChar(20)
  invoiceTitle     String?  @map("invoice_title") @db.VarChar(255)
  taxType          String?  @map("tax_type") @db.VarChar(20)
  invoiceAmount    Decimal? @map("invoice_amount") @db.Decimal(12, 2)
  supplierDiscount Decimal? @default(0) @map("supplier_discount") @db.Decimal(12, 2)
  amount           Decimal  @default(0) @db.Decimal(12, 2)
  tax              Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal  @default(0) @map("total_amount") @db.Decimal(12, 2)
  status           String   @default("待核銷") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  details  SalesDetail[]
  expenses Expense[]

  @@index([invoiceNo])
  @@index([invoiceDate])
  @@map("sales_masters")
}

model SalesDetail {
  id             Int     @id @default(autoincrement())
  salesId        Int     @map("sales_id")
  purchaseItemId String  @map("purchase_item_id") @db.VarChar(50)
  purchaseId     Int?    @map("purchase_id")
  purchaseNo     String? @map("purchase_no") @db.VarChar(50)
  purchaseDate   String? @map("purchase_date") @db.VarChar(20)
  warehouse      String? @db.VarChar(100)
  supplierId     Int?    @map("supplier_id")
  productId      Int?    @map("product_id")
  quantity       Int?
  unitPrice      Decimal? @map("unit_price") @db.Decimal(12, 2)
  note           String?  @db.Text
  subtotal       Decimal? @db.Decimal(12, 2)

  salesMaster SalesMaster @relation(fields: [salesId], references: [id], onDelete: Cascade)

  @@index([salesId])
  @@index([purchaseItemId])
  @@index([productId])                                         // year-end inventory groupBy
  @@map("sales_details")
}

// ============================================
// 付款模組 (spec3)
// ============================================

model Payment {
  id             Int      @id @default(autoincrement())
  paymentNo      String   @unique @map("payment_no") @db.VarChar(50)
  invoiceIds     Json     @default("[]") @map("invoice_ids")
  paymentDate    String?  @map("payment_date") @db.VarChar(20)
  paymentMethod  String   @default("月結") @map("payment_method") @db.VarChar(20)
  amount         Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("未完成") @db.VarChar(20)
  checkIssueDate String?  @map("check_issue_date") @db.VarChar(20)
  checkDate      String?  @map("check_date") @db.VarChar(20)
  checkNo        String?  @map("check_no") @db.VarChar(50)
  checkAccount   String?  @map("check_account") @db.VarChar(100)
  note           String?  @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([paymentDate])
  @@map("payments")
}

// ============================================
// 支出管理 (spec3)
// ============================================

model Expense {
  id                  Int      @id @default(autoincrement())
  invoiceId           Int      @map("invoice_id")
  invoiceNo           String   @map("invoice_no") @db.VarChar(50)
  invoiceDate         String?  @map("invoice_date") @db.VarChar(20)
  amount              Decimal  @default(0) @db.Decimal(12, 2)
  actualPaymentDate   String?  @map("actual_payment_date") @db.VarChar(20)
  actualPaymentAmount Decimal  @default(0) @map("actual_payment_amount") @db.Decimal(12, 2)
  status              String   @default("未完成") @db.VarChar(20)
  supplierId          Int?     @map("supplier_id")
  supplierName        String?  @map("supplier_name") @db.VarChar(255)
  warehouse           String?  @db.VarChar(100)
  sourceType          String?  @map("source_type") @db.VarChar(50)
  sourceRecordId      Int?     @map("source_record_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  salesMaster Supplier?    @relation(fields: [supplierId], references: [id])
  invoice     SalesMaster  @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([supplierId])
  @@index([status])
  @@map("expenses")
}

// ============================================
// 分析模組 - 價格歷史 (spec0 v3)
// ============================================

model PriceHistory {
  id               Int      @id @default(autoincrement())
  supplierId       Int      @map("supplier_id")
  productId        Int      @map("product_id")
  warehouse        String?  @db.VarChar(100) // spec0 v3: 館別
  purchaseMasterId Int?     @map("purchase_master_id") // spec0 v3: 溯源
  purchaseDetailId Int?     @map("purchase_detail_id") // spec0 v3: 溯源
  purchaseDate     String   @map("purchase_date") @db.VarChar(20)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  quantity         Int?     // spec0 v3: 採購數量
  taxType          String?  @map("tax_type") @db.VarChar(20) // spec0 v3: 稅別
  isSuperseded     Boolean  @default(false) @map("is_superseded") // spec0 v3: 是否已被取代
  createdAt        DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([purchaseDate])
  @@index([productId, supplierId])                           // spec24: 比價快取核心
  @@index([productId, warehouse, purchaseDate(sort: Desc)])  // spec24: 本館最近採購
  @@index([supplierId, purchaseDate])                        // spec24: 廠商採購分析
  @@index([productId, supplierId, purchaseDate(sort: Desc)]) // voucher export batch price lookup
  @@map("price_history")
}

model PriceComparison {
  productId  Int     @map("product_id")
  supplierId Int     @map("supplier_id")
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  date       String  @db.VarChar(20)

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@id([productId, supplierId, date])
  @@map("price_comparisons")
}

// ============================================
// 採購比價快取 (spec0 v3 / spec24)
// ============================================

model PriceSummaryCache {
  id               Int       @id @default(autoincrement())
  productId        Int       @map("product_id")
  supplierId       Int       @map("supplier_id")
  warehouse        String    @db.VarChar(100)
  latestPrice      Decimal?  @map("latest_price") @db.Decimal(12, 2)
  latestDate       String?   @map("latest_date") @db.VarChar(20)
  lowestPrice      Decimal?  @map("lowest_price") @db.Decimal(12, 2)
  lowestDate       String?   @map("lowest_date") @db.VarChar(20)
  avgPrice3m       Decimal?  @map("avg_price_3m") @db.Decimal(12, 2)   // 排程計算
  avgPrice12m      Decimal?  @map("avg_price_12m") @db.Decimal(12, 2)  // 排程計算
  purchaseCount12m Int?      @map("purchase_count_12m")                 // 排程計算
  lastUpdated      DateTime  @default(now()) @map("last_updated")

  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId, warehouse])
  @@index([productId, supplierId])
  @@index([productId, warehouse])
  @@map("price_summary_caches")
}

model DepartmentExpense {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  department  String   @db.VarChar(100)
  category    String   @db.VarChar(100)
  tax         Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([year, month])
  @@map("department_expenses")
}

// ============================================
// 現金流管理模組 (spec6 v10)
// ============================================

model CashAccount {
  id                       Int       @id @default(autoincrement())
  accountCode              String?   @unique @map("account_code") @db.VarChar(20)
  name                     String    @db.VarChar(100)
  type                     String    @db.VarChar(20)        // 現金, 銀行存款, 代墊款, 信用卡
  warehouse                String?   @db.VarChar(100)
  openingBalance           Decimal   @default(0) @map("opening_balance") @db.Decimal(12, 2)
  currentBalance           Decimal   @default(0) @map("current_balance") @db.Decimal(12, 2)
  isActive                 Boolean   @default(true) @map("is_active")
  isConfidential           Boolean   @default(false) @map("is_confidential")
  // spec6 v10: auto transaction tracking
  autoTransactionCount     Int?      @map("auto_transaction_count")
  lastAutoTransactionDate  String?   @map("last_auto_transaction_date") @db.VarChar(20)
  // spec6 v7: 代墊款管理
  advanceOwnerType         String?   @map("advance_owner_type") @db.VarChar(20)
  advanceOwnerName         String?   @map("advance_owner_name") @db.VarChar(100)
  advanceOwnerContact      String?   @map("advance_owner_contact") @db.VarChar(100)
  repaymentAlertDays       Int?      @map("repayment_alert_days")
  note                     String?   @db.VarChar(500)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  transactions       CashTransaction[]        @relation("AccountTransactions")
  transfersIn        CashTransaction[]        @relation("TransferToAccount")
  reconciliations    BankReconciliation[]
  statementImports   BankStatementImport[]
  checksSource       Check[]                  @relation("CheckSourceAccount")
  checksDestination  Check[]                  @relation("CheckDestinationAccount")
  loanMasters        LoanMaster[]
  rentalProperties   RentalProperty[]         @relation("RentCollectAccount")
  depositProperties  RentalProperty[]         @relation("DepositAccount")
  monthlySnapshots   AccountMonthlySnapshot[]
  cashCountConfigs   CashCountConfig[]
  cashCounts         CashCount[]

  @@index([warehouse])
  @@index([type])
  @@index([isActive])
  @@map("cash_accounts")
}

model CashCategory {
  id                   Int      @id @default(autoincrement())
  name                 String   @db.VarChar(100)
  type                 String   @db.VarChar(10)
  warehouse            String?  @db.VarChar(100)
  accountingSubjectId  Int?     @map("accounting_subject_id")
  isActive             Boolean  @default(true) @map("is_active")
  isSystemDefault      Boolean  @default(false) @map("is_system_default")
  systemCode           String?  @map("system_code") @db.VarChar(50)
  createdAt            DateTime @default(now()) @map("created_at")

  accountingSubject AccountingSubject? @relation(fields: [accountingSubjectId], references: [id])
  transactions      CashTransaction[]

  @@index([type])
  @@index([systemCode])
  @@index([accountingSubjectId])
  @@map("cash_categories")
}

model CashTransaction {
  id                              Int       @id @default(autoincrement())
  transactionNo                   String    @unique @map("transaction_no") @db.VarChar(50)
  transactionDate                 String    @map("transaction_date") @db.VarChar(20)
  type                            String    @db.VarChar(10)     // 收入, 支出, 移轉
  warehouse                       String?   @db.VarChar(100)
  accountId                       Int       @map("account_id")
  categoryId                      Int?      @map("category_id")
  supplierId                      Int?      @map("supplier_id")
  paymentNo                       String?   @map("payment_no") @db.VarChar(50)
  amount                          Decimal   @db.Decimal(12, 2)
  fee                             Decimal   @default(0) @db.Decimal(12, 2)
  hasFee                          Boolean   @default(false) @map("has_fee")
  accountingSubject               String?   @map("accounting_subject") @db.VarChar(100)
  paymentTerms                    String?   @map("payment_terms") @db.VarChar(50)
  description                     String?   @db.VarChar(500)
  transferAccountId               Int?      @map("transfer_account_id")
  linkedTransactionId             Int?      @map("linked_transaction_id")
  sourceType                      String?   @map("source_type") @db.VarChar(50)  // 23 types (spec6 v10)
  sourceRecordId                  Int?      @map("source_record_id")
  // spec6 v10: 自動交易標記
  isAutoCreated                   Boolean   @default(false) @map("is_auto_created")
  autoCreationReason              String?   @map("auto_creation_reason") @db.VarChar(50)
  linkedReconciliationId          Int?      @map("linked_reconciliation_id")
  linkedBankStatementLineId       Int?      @map("linked_bank_statement_line_id")
  linkedCreditCardStatementLineId Int?      @map("linked_credit_card_statement_line_id")
  isNonCashExpense                Boolean   @default(false) @map("is_non_cash_expense")
  createdBy                       Int?      @map("created_by")
  // reversal fields
  status                          String    @default("已確認") @db.VarChar(20)
  isReversal                      Boolean   @default(false) @map("is_reversal")
  reversalOfId                    Int?      @map("reversal_of_id")
  reversedById                    Int?      @map("reversed_by_id")
  version                         Int       @default(0)
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime  @updatedAt @map("updated_at")

  account         CashAccount   @relation("AccountTransactions", fields: [accountId], references: [id])
  category        CashCategory? @relation(fields: [categoryId], references: [id])
  transferAccount CashAccount?  @relation("TransferToAccount", fields: [transferAccountId], references: [id])

  @@index([transactionDate])
  @@index([accountId])
  @@index([type])
  @@index([warehouse])
  @@index([paymentNo])
  @@index([sourceType, sourceRecordId])
  @@index([accountId, transactionDate(sort: Desc)])  // spec24
  @@index([sourceType, transactionDate])              // spec24
  @@index([isNonCashExpense, transactionDate])         // spec24
  @@map("cash_transactions")
}

// ============================================
// 會計科目
// ============================================

model AccountingSubject {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(50)
  subcategory String   @db.VarChar(100)
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cashCategories CashCategory[]

  @@index([category])
  @@index([code])
  @@map("accounting_subjects")
}

// ============================================
// 認證與權限模組 (spec8 v5)
// ============================================

model User {
  id                      Int       @id @default(autoincrement())
  email                   String    @unique @db.VarChar(255)
  password                String    @db.VarChar(255)
  name                    String    @db.VarChar(100)
  role                    String    @default("user") @db.VarChar(20)
  permissions             Json      @default("[]")
  isActive                Boolean   @default(true) @map("is_active")
  warehouseRestriction    String?   @map("warehouse_restriction") @db.VarChar(100)
  notificationSettings    Json?     @map("notification_settings")
  // spec8 v5: 通知相關
  notificationEmail       String?   @map("notification_email") @db.VarChar(255)
  lineUserId              String?   @map("line_user_id") @db.VarChar(100)
  lineDisplayName         String?   @map("line_display_name") @db.VarChar(100)
  lineLinkedAt            DateTime? @map("line_linked_at")
  lineBindingToken        String?   @map("line_binding_token") @db.VarChar(255)
  lineBindingExpiredAt    DateTime? @map("line_binding_expired_at")
  lastLoginAt             DateTime? @map("last_login_at")
  passwordChangedAt       DateTime? @map("password_changed_at")
  passwordHistory         Json      @default("[]") @map("password_history") // Recent bcrypt hashes to prevent reuse
  failedLoginAttempts     Int       @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime? @map("locked_until")
