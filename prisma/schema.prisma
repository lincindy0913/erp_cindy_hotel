  closingValue     Decimal  @default(0) @map("closing_value") @db.Decimal(15, 2)
  isLocked         Boolean  @default(false) @map("is_locked")
  isStale          Boolean  @default(false) @map("is_stale")
  createdAt        DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, warehouse, snapshotYear, snapshotMonth])
  @@index([productId, warehouse])
  @@index([snapshotYear, snapshotMonth])
  @@map("inventory_monthly_snapshots")
}

model MonthlyAggregation {
