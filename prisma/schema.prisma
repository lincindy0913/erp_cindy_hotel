// ============================================
// 信用卡撥款對帳單 (per billing date per merchant)
// ============================================

model CreditCardStatement {
  id                Int       @id @default(autoincrement())
  merchantConfigId  Int?      @map("merchant_config_id")
  warehouseId       Int       @map("warehouse_id")
  warehouse         String    @db.VarChar(100)                   // 館別名稱
  bankName          String    @map("bank_name") @db.VarChar(100) // 銀行名稱
  merchantId        String?   @map("merchant_id") @db.VarChar(50) // 特店代號
  merchantName      String?   @map("merchant_name") @db.VarChar(200)
  billingDate       String    @map("billing_date") @db.VarChar(20)  // 請款日
  paymentDate       String?   @map("payment_date") @db.VarChar(20) // 撥款日期
  accountNo         String?   @map("account_no") @db.VarChar(100)  // 入帳帳號
  totalCount        Int       @default(0) @map("total_count")      // 請款筆數
  totalAmount       Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)  // 請款金額
  adjustment        Decimal   @default(0) @db.Decimal(14, 2)       // 調整
  totalFee          Decimal   @default(0) @map("total_fee") @db.Decimal(14, 2)     // 手續費
  serviceFee        Decimal   @default(0) @map("service_fee") @db.Decimal(14, 2)   // 服務費
  otherFee          Decimal   @default(0) @map("other_fee") @db.Decimal(14, 2)     // 費用
  netAmount         Decimal   @default(0) @map("net_amount") @db.Decimal(14, 2)    // 撥款淨額
  pmsAmount         Decimal?  @map("pms_amount") @db.Decimal(14, 2)  // PMS 信用卡收入
  difference        Decimal?  @db.Decimal(14, 2)                     // 差異金額
  status            String    @default("pending") @db.VarChar(20)    // pending/matched/confirmed
  confirmedBy       String?   @map("confirmed_by") @db.VarChar(255)
  confirmedAt       DateTime? @map("confirmed_at")
  note              String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  batchLines   CreditCardBatchLine[]
  feeDetails   CreditCardFeeDetail[]

  @@index([warehouseId])
  @@index([billingDate])
  @@index([status])
  @@map("credit_card_statements")
}

// ============================================
// 信用卡批次明細 (per terminal/batch/card type)
// ============================================

model CreditCardBatchLine {
  id              Int      @id @default(autoincrement())
  statementId     Int      @map("statement_id")
  billingDate     String   @map("billing_date") @db.VarChar(20)
  settlementDate  String?  @map("settlement_date") @db.VarChar(20) // 機台結帳日
  terminalId      String?  @map("terminal_id") @db.VarChar(50)     // 終端機
  batchNo         String?  @map("batch_no") @db.VarChar(20)        // 批次號碼
  cardType        String   @map("card_type") @db.VarChar(20)       // VISA/MASTER/JCB/CUP
  count           Int      @default(0)                               // 筆數
  amount          Decimal  @db.Decimal(14, 2)                        // 請款金額
  createdAt       DateTime @default(now()) @map("created_at")

  statement CreditCardStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
  @@map("credit_card_batch_lines")
}

// ============================================
// 信用卡手續費明細 (國內/國外/自行 per card type)
// ============================================

model CreditCardFeeDetail {
  id              Int      @id @default(autoincrement())
  statementId     Int      @map("statement_id")
  origin          String   @db.VarChar(20)       // 國內/國外/自行
  cardType        String   @map("card_type") @db.VarChar(20)  // VISA/MASTER/JCB/CUP
  count           Int      @default(0)
  amount          Decimal  @db.Decimal(14, 2)     // 請款金額
  fee             Decimal  @db.Decimal(14, 2)     // 手續費
  feeRate         Decimal? @map("fee_rate") @db.Decimal(5, 2) // 計算出的費率%
  createdAt       DateTime @default(now()) @map("created_at")

  statement CreditCardStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
  @@map("credit_card_fee_details")
}

// ============================================
// 付款單與出納執行 (spec3)
// ============================================

model PaymentOrder {
  id             Int       @id @default(autoincrement())
  orderNo        String    @unique @map("order_no") @db.VarChar(50)
  invoiceIds     Json      @default("[]") @map("invoice_ids")
  supplierId     Int?      @map("supplier_id")
  supplierName   String?   @map("supplier_name") @db.VarChar(255)
  warehouse      String?   @db.VarChar(100)
  paymentMethod  String    @map("payment_method") @db.VarChar(50)
  amount         Decimal   @db.Decimal(12, 2)
  discount       Decimal   @default(0) @db.Decimal(12, 2)
  netAmount      Decimal   @map("net_amount") @db.Decimal(12, 2)
  dueDate        String?   @map("due_date") @db.VarChar(20)
  accountId      Int?      @map("account_id")
  checkNo        String?   @map("check_no") @db.VarChar(50)
  checkAccount   String?   @map("check_account") @db.VarChar(100)
  checkIssueDate String?   @map("check_issue_date") @db.VarChar(20)
  checkDueDate   String?   @map("check_due_date") @db.VarChar(20)
  summary        String?   @db.VarChar(500)
  note           String?   @db.Text
  status         String    @default("待出納") @db.VarChar(20)
  sourceType     String?   @map("source_type") @db.VarChar(50)
  sourceRecordId Int?     @map("source_record_id")
  createdBy      String?   @map("created_by") @db.VarChar(255)
  rejectedBy     String?   @map("rejected_by") @db.VarChar(255)
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason") @db.Text
  version        Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  executions CashierExecution[]

  @@index([status])
  @@index([supplierId])
  @@index([warehouse])
  @@index([dueDate])
  @@index([sourceType])
  @@index([orderNo])
  @@index([createdAt])
  @@map("payment_orders")
}

model CashierExecution {
  id                Int      @id @default(autoincrement())
  executionNo       String   @unique @map("execution_no") @db.VarChar(50)
  paymentOrderId    Int      @map("payment_order_id")
