  expectedAmount        Decimal   @map("expected_amount") @db.Decimal(12, 2)
  actualDate            String?   @map("actual_date") @db.VarChar(20)
  actualAmount          Decimal?  @map("actual_amount") @db.Decimal(12, 2)
  accountId             Int?      @map("account_id")
  paymentMethod         String?   @map("payment_method") @db.VarChar(20)
  matchTransferRef      String?   @map("match_transfer_ref") @db.VarChar(100)
  matchBankAccountName  String?   @map("match_bank_account_name") @db.VarChar(100)
