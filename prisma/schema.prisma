  salesMasterId    Int?     @map("sales_master_id")
  paymentOrderId   Int?     @map("payment_order_id")
  purchaseNo       String?  @map("linked_purchase_no") @db.VarChar(50)
  salesNo          String?  @map("linked_sales_no") @db.VarChar(50)
  paymentOrderNo   String?  @map("linked_payment_order_no") @db.VarChar(50)
  status          String    @default("待確認") @db.VarChar(20)
  confirmedBy     String?   @map("confirmed_by") @db.VarChar(255)
  confirmedAt     DateTime? @map("confirmed_at")
  voidedBy        String?   @map("voided_by") @db.VarChar(255)
  voidedAt        DateTime? @map("voided_at")
  voidReason      String?   @map("void_reason") @db.Text
  note            String?   @db.Text
  createdBy       String    @map("created_by") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  template        CommonExpenseTemplate @relation(fields: [templateId], references: [id])
