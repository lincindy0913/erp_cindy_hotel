// ============================================
// 存簿對帳 (spec17)
// ============================================

model BankAccountFormat {
  id                Int      @id @default(autoincrement())
  bankName          String   @map("bank_name") @db.VarChar(100)
  bankCode          String?  @map("bank_code") @db.VarChar(10)
  fileEncoding      String   @default("UTF-8") @map("file_encoding") @db.VarChar(20)
  fileType          String   @default("csv") @map("file_type") @db.VarChar(10)
  hasHeaderRow      Boolean  @default(true) @map("has_header_row")
  headerRowIndex    Int      @default(0) @map("header_row_index")
  skipTopRows       Int      @default(0) @map("skip_top_rows")
  skipBottomRows    Int      @default(0) @map("skip_bottom_rows")
  dateColumn        String?  @map("date_column") @db.VarChar(50)
  dateFormat        String?  @map("date_format") @db.VarChar(50)
  descriptionColumn String?  @map("description_column") @db.VarChar(50)
  debitColumn       String?  @map("debit_column") @db.VarChar(50)
  creditColumn      String?  @map("credit_column") @db.VarChar(50)
  amountColumn      String?  @map("amount_column") @db.VarChar(50)
  balanceColumn     String?  @map("balance_column") @db.VarChar(50)
  referenceColumn   String?  @map("reference_column") @db.VarChar(50)
  closingBalanceCell String? @map("closing_balance_cell") @db.VarChar(50)
  isBuiltIn         Boolean  @default(false) @map("is_built_in")
  sampleRow         String?  @map("sample_row") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  imports BankStatementImport[]

  @@map("bank_account_formats")
}

model BankStatementImport {
  id                      Int      @id @default(autoincrement())
  importNo                String   @unique @map("import_no") @db.VarChar(50)
  accountId               Int      @map("account_id")
  bankFormatId            Int      @map("bank_format_id")
  statementYear           Int      @map("statement_year")
  statementMonth          Int      @map("statement_month")
  statementStartDate      String?  @map("statement_start_date") @db.VarChar(20)
  statementEndDate        String?  @map("statement_end_date") @db.VarChar(20)
  statementOpeningBalance Decimal? @map("statement_opening_balance") @db.Decimal(14, 2)
  statementClosingBalance Decimal? @map("statement_closing_balance") @db.Decimal(14, 2)
  rawFileName             String   @map("raw_file_name") @db.VarChar(255)
  rawFileUrl              String?  @map("raw_file_url") @db.VarChar(500)
  parseStatus             String   @default("pending") @map("parse_status") @db.VarChar(20)
  parseErrorMsg           String?  @map("parse_error_msg") @db.Text
  totalLines              Int      @default(0) @map("total_lines")
  parsedLines             Int      @default(0) @map("parsed_lines")
  importedBy              String?  @map("imported_by") @db.VarChar(255)
  importedAt              DateTime @default(now()) @map("imported_at")

  account    CashAccount          @relation(fields: [accountId], references: [id])
  bankFormat BankAccountFormat    @relation(fields: [bankFormatId], references: [id])
  lines      BankStatementLine[]
  reconciliation BankReconciliation?

  @@index([accountId])
  @@index([statementYear, statementMonth])
  @@map("bank_statement_imports")
}

model BankStatementLine {
  id                    Int      @id @default(autoincrement())
  importId              Int      @map("import_id")
  accountId             Int      @map("account_id")
  lineNo                Int      @map("line_no")
  txDate                String   @map("tx_date") @db.VarChar(20)
  valueDate             String?  @map("value_date") @db.VarChar(20)
  description           String?  @db.VarChar(500)
  debitAmount           Decimal  @default(0) @map("debit_amount") @db.Decimal(14, 2)
  creditAmount          Decimal  @default(0) @map("credit_amount") @db.Decimal(14, 2)
  netAmount             Decimal  @default(0) @map("net_amount") @db.Decimal(14, 2)
  runningBalance        Decimal? @map("running_balance") @db.Decimal(14, 2)
  referenceNo           String?  @map("reference_no") @db.VarChar(100)
  transactionType       String?  @map("transaction_type") @db.VarChar(50) // spec17 v3: 交易分類
  matchStatus           String   @default("unprocessed") @map("match_status") @db.VarChar(20)
  matchedTransactionId  Int?     @map("matched_transaction_id")
  matchedBy             String?  @map("matched_by") @db.VarChar(20)
  reconciliationId      Int?     @map("reconciliation_id")
  note                  String?  @db.Text

  import BankStatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([accountId])
  @@index([txDate])
  @@index([matchStatus])
  @@index([accountId, txDate]) // spec24
  @@map("bank_statement_lines")
}

model BankReconciliation {
  id                    Int       @id @default(autoincrement())
  reconciliationNo      String    @unique @map("reconciliation_no") @db.VarChar(50)
  accountId             Int       @map("account_id")
  statementYear         Int       @map("statement_year")
  statementMonth        Int       @map("statement_month")
  importId              Int?      @unique @map("import_id")
  openingBalance        Decimal   @default(0) @map("opening_balance") @db.Decimal(14, 2)
  closingBalanceSystem  Decimal   @default(0) @map("closing_balance_system") @db.Decimal(14, 2)
  closingBalanceBank    Decimal   @default(0) @map("closing_balance_bank") @db.Decimal(14, 2)
  difference            Decimal   @default(0) @db.Decimal(14, 2)
  totalBankLines        Int       @default(0) @map("total_bank_lines")
  matchedLines          Int       @default(0) @map("matched_lines")
  bankOnlyLines         Int       @default(0) @map("bank_only_lines")
  systemOnlyLines       Int       @default(0) @map("system_only_lines")
  amountDiffLines       Int       @default(0) @map("amount_diff_lines")
  adjustmentCount       Int       @default(0) @map("adjustment_count")
  status                String    @default("draft") @db.VarChar(20)
  confirmedBy           String?   @map("confirmed_by") @db.VarChar(255)
  confirmedAt           DateTime? @map("confirmed_at")
  differenceExplained   String?   @map("difference_explained") @db.Text
  note                  String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  account             CashAccount                @relation(fields: [accountId], references: [id])
  import              BankStatementImport?       @relation(fields: [importId], references: [id])
  txSuggestions       BankTransactionSuggestion[]

  @@unique([accountId, statementYear, statementMonth])
  @@index([accountId])
  @@index([statementYear, statementMonth])
  @@index([status])
  @@map("bank_reconciliations")
}

// ============================================
// 信用卡特約商店設定 (per warehouse)
// ============================================

model CreditCardMerchantConfig {
  id                Int      @id @default(autoincrement())
  warehouseId       Int      @map("warehouse_id")
