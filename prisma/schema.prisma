  records         CommonExpenseRecord[]

  @@index([categoryId])
  @@index([isActive])
  @@index([templateType])
  @@map("common_expense_templates")
}

model TemplateEntryLine {
  id              Int       @id @default(autoincrement())
  templateId      Int       @map("template_id")
  entryType       String    @map("entry_type") @db.VarChar(10)
  accountingCode  String    @map("accounting_code") @db.VarChar(20)
  accountingName  String    @map("accounting_name") @db.VarChar(100)
  summary         String?   @db.VarChar(500)
  defaultAmount   Decimal?  @map("default_amount") @db.Decimal(15, 2)
  supplierId      Int?      @map("supplier_id")    // 廠商（選填）
  supplierName    String?   @map("supplier_name") @db.VarChar(255)
  warehouse       String?   @db.VarChar(100)       // 館別
  paymentMethod   String?   @map("payment_method") @db.VarChar(50)
  accountId       Int?      @map("account_id")     // 轉帳存簿 (CashAccount)
  advancedBy      String?   @map("advanced_by") @db.VarChar(100)  // 代墊員工姓名 (信用卡/員工代付)
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")

  template        CommonExpenseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_entry_lines")
}

model CommonExpenseRecord {
