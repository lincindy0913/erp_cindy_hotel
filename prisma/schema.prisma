  supplierId            Int?      @map("supplier_id")
  status                String    @default("pending") @db.VarChar(20)
  cashTransactionId     Int?      @map("cash_transaction_id")
  paymentOrderId        Int?      @map("payment_order_id")  // 連動出納待出納，執行後入金流
  // 員工代墊款欄位
  isEmployeeAdvance     Boolean   @default(false) @map("is_employee_advance")
  advancedBy            String?   @map("advanced_by") @db.VarChar(100)       // 代墊員工姓名
  advancePaymentMethod  String?   @map("advance_payment_method") @db.VarChar(50) // 現金, 信用卡
  employeeAdvanceId     Int?      @map("employee_advance_id")
