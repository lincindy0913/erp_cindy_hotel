  merchantId        String   @map("merchant_id") @db.VarChar(50)   // 特店代號 310800073
  merchantName      String   @map("merchant_name") @db.VarChar(200) // 特店名稱
  accountNo         String?  @map("account_no") @db.VarChar(100)   // 入帳帳號
  accountName       String?  @map("account_name") @db.VarChar(200) // 入帳戶名
  cashAccountId     Int?     @map("cash_account_id")               // 對應資金帳戶
  domesticFeeRate   Decimal  @default(1.70) @map("domestic_fee_rate") @db.Decimal(5, 2)  // 國內手續費率%
  foreignFeeRate    Decimal  @default(2.30) @map("foreign_fee_rate") @db.Decimal(5, 2)   // 國外手續費率%
  selfFeeRate       Decimal  @default(1.70) @map("self_fee_rate") @db.Decimal(5, 2)      // 自行卡手續費率%
